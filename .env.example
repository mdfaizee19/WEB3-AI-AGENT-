# CROO Network endpoints
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# SDK Keys — one per agent, obtained from the CROO Dashboard
CROO_SDK_KEY_COORDINATOR=croo_sk_...
CROO_SDK_KEY_WEB_RESEARCH=croo_sk_...
CROO_SDK_KEY_SOURCE_VERIFICATION=croo_sk_...
CROO_SDK_KEY_SYNTHESIS=croo_sk_...
CROO_SDK_KEY_RISK=croo_sk_...

# Service IDs — assigned by CROO Dashboard when registering each specialist service
CROO_SERVICE_ID_WEB_RESEARCH=
CROO_SERVICE_ID_SOURCE_VERIFICATION=
CROO_SERVICE_ID_SYNTHESIS=
CROO_SERVICE_ID_RISK=

# USDC on Base mainnet (do not change)
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# AI providers
GEMINI_API_KEY=                 # Google AI Studio — used by Synthesis and Risk agents
ETHERSCAN_API_KEY=              # Etherscan — used by Risk agent for on-chain data
